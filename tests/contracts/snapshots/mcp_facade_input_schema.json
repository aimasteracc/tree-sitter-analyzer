[
  {
    "facade": "search",
    "schema": {
      "additionalProperties": true,
      "properties": {
        "action": {
          "description": "Which capability to invoke. One of: batch, chain, content, grep, query, select, subscribe, symbol, unsubscribe",
          "enum": [
            "batch",
            "chain",
            "content",
            "grep",
            "query",
            "select",
            "subscribe",
            "symbol",
            "unsubscribe"
          ],
          "type": "string"
        },
        "file_path": {
          "description": "Target file path.",
          "type": "string"
        },
        "function_name": {
          "description": "Function name (alias of symbol).",
          "type": "string"
        },
        "kind": {
          "description": "Symbol kind filter for action=symbol (default: any).",
          "enum": [
            "function",
            "method",
            "class",
            "enum",
            "variable",
            "import",
            "constant",
            "any"
          ],
          "type": "string"
        },
        "language": {
          "description": "Language hint (usually auto).",
          "type": "string"
        },
        "limit": {
          "description": "Max results.",
          "type": "integer"
        },
        "mode": {
          "description": "Action sub-mode (e.g. summary|cycles).",
          "type": "string"
        },
        "output_format": {
          "description": "Output format (toon|json).",
          "type": "string"
        },
        "query": {
          "description": "Search query/pattern.",
          "type": "string"
        },
        "scope": {
          "description": "Action discriminator (e.g. point|graph).",
          "type": "string"
        },
        "symbol": {
          "description": "Symbol/function name.",
          "type": "string"
        }
      },
      "required": [
        "action"
      ],
      "type": "object"
    }
  },
