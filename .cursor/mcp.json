{
  "mcpServers": {
    "tree-sitter-analyzer-local": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "C:/git-private/tree-sitter-analyzer-workspace/tree-sitter-analyzer-v2",
        "python",
        "-m",
        "tree_sitter_analyzer_v2.mcp.server"
      ],
      "env": {
        "TREE_SITTER_PROJECT_ROOT": "C:/git-private/tree-sitter-analyzer-workspace/tree-sitter-analyzer-v1",
        "TREE_SITTER_OUTPUT_PATH": "C:/git-private/tree-sitter-analyzer-workspace/tree-sitter-analyzer-v1/.analysis",
        "TREE_SITTER_ANALYZER_ENABLE_FILE_LOG": "true",
        "TREE_SITTER_ANALYZER_LOG_DIR": "C:/git-private/tree-sitter-analyzer-workspace/tree-sitter-analyzer-v1/.analysis",
        "TREE_SITTER_ANALYZER_LOG_LEVEL": "DEBUG"
      },
      "timeout": 3600,
      "disabled": false
    }
  }
}
